local function executeCommand(senderId, cmd, data)
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if cmd == "KILL_PLAYER" then
        if hum then hum.Health = 0 end
        
    elseif cmd == "START_KILL_LOOP" then
        if killLoops[senderId] then killLoops[senderId]:Disconnect() end
        killLoops[senderId] = RS.Heartbeat:Connect(function()
            local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h then h.Health = 0 end
        end)
        task.delay(30, function()
            if killLoops[senderId] then
                killLoops[senderId]:Disconnect()
                killLoops[senderId] = nil
            end
        end)
        
    elseif cmd == "STOP_KILL_LOOP" then
        if killLoops[senderId] then
            killLoops[senderId]:Disconnect()
            killLoops[senderId] = nil
        end
        
    elseif cmd == "FREEZE_PLAYER" then
        if hum then
            hum.WalkSpeed = 0
            hum.JumpPower = 0
        end
        
    elseif cmd == "UNFREEZE_PLAYER" then
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
        
    elseif cmd == "KICK_PLAYER" then
        task.delay(0.5, function() LP:Kick(data or "Kicked") end)
        
    elseif cmd == "SPECTATE" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character then
            Camera.CameraSubject = target.Character:FindFirstChild("HumanoidRootPart") or target.Character
        end
        
    elseif cmd == "TP_TO" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character and root then
            local tr = target.Character:FindFirstChild("HumanoidRootPart")
            if tr then root.CFrame = tr.CFrame * CFrame.new(0, 3, 5) end
        end
        
    elseif cmd == "BRING" then
