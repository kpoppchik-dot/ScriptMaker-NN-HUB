-- Spin
local function spin()
    if Spin.connection then
        Spin.connection:Disconnect()
        Spin.connection = nil
        return
    end
    
    local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local ang = 0
    Spin.connection = RS.RenderStepped:Connect(function()
        ang = ang + 10
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(ang), 0)
    end)
    
    task.delay(5, function()
        if Spin.connection then
            Spin.connection:Disconnect()
            Spin.connection = nil
        end
    end)
end

