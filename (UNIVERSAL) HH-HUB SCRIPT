local httpOk=false

local function dbSet(key,value,ttl)
    local ok=pcall(function()
        HS:RequestAsync({
            Url=DB_BASE..key,Method="POST",
            Headers={["Content-Type"]="text/plain",["X-Expire"]=tostring(ttl or DB_TTL+5)},
            Body=tostring(value)
        })
    end)
    if ok then httpOk=true end
    return ok
end

local function dbGet(key)
    local ok,res=pcall(function() return HS:GetAsync(DB_BASE..key,true) end)
    if ok and res and res~="" then httpOk=true; return res end
    return nil
end

local function dbDel(key)
    pcall(function() HS:RequestAsync({Url=DB_BASE..key,Method="DELETE"}) end)
end

