local function parsePresence(raw)
    if not raw or raw=="" then return nil end
    local p=raw:split("§")
    if #p<5 then return nil end
    return{displayName=p[1],name=p[2],placeId=p[3],jobId=p[4],lastSeen=tonumber(p[5]) or 0}
end

local Registry={}

local function fetchAllUsers()
    local keysRaw=pcall(function() return HS:GetAsync(DB_BASE.."?prefix=presence_&format=keys",true) end)
    local ok,keysData=pcall(function() return HS:GetAsync(DB_BASE.."?prefix=presence_&format=keys",true) end)
    if not ok or not keysData then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LP then
                local f=pcall(function() return plr:GetAttribute(NET_FLAG_LOCAL)=="1" end)
                local ok2,flag=pcall(function() return plr:GetAttribute(NET_FLAG_LOCAL) end)
                if ok2 and flag=="1" then
                    local uid=tostring(plr.UserId)
                    Registry[uid]={displayName=plr.DisplayName,name=plr.Name,placeId=tostring(game.PlaceId),jobId=tostring(game.JobId):sub(1,8),lastSeen=tick(),userId=uid,isLocal=false,sameServer=true}
                end
            end
        end
        return
    end
    httpOk=true
    local newReg={}
    for key in keysData:gmatch("[^\n]+") do
        key=key:match("^%s*(.-)%s*$")
        if key:sub(1,9)=="presence_" then
            local uid=key:sub(10)
            local raw=dbGet(key)
            local info=parsePresence(raw)
            if info then
                info.userId=uid
                info.sameServer=(info.jobId==tostring(game.JobId):sub(1,8))
                newReg[uid]=info
            end
        end
    end
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LP then
            local ok2,flag=pcall(function() return plr:GetAttribute(NET_FLAG_LOCAL) end)
            if ok2 and flag=="1" then
                local uid=tostring(plr.UserId)
                if not newReg[uid] then
                    newReg[uid]={displayName=plr.DisplayName,name=plr.Name,placeId=tostring(game.PlaceId),jobId=tostring(game.JobId):sub(1,8),lastSeen=tick(),userId=uid,isLocal=false,sameServer=true}
                end
            end
        end
    end
    local now=math.floor(tick())
    for uid,info in pairs(newReg) do
        if now-info.lastSeen>DB_TTL+10 then newReg[uid]=nil end
    end
    Registry=newReg
end

