            if UIS:IsKeyDown(Enum.KeyCode.D) then r.CFrame=r.CFrame*CFrame.new(-0.5,0,0) end
        end)
        task.delay(10,function() if conn then conn:Disconnect() end end)

    elseif cmd=="SPAM_NOTIFICATIONS" then
        task.spawn(function()
            for i=1,30 do
                safeNotify("⚠️ Администратор","Вы были наказаны #"..i,1)
                task.wait(0.2)
            end
        end)
    end
end

-- GOD MODE
local GodMode={active=false,connections={}}

local function enableGodMode()
    if GodMode.active then return end
    GodMode.active=true
    local function apply()
        local char=LP.Character;if not char then return end
        local hum=char:FindFirstChildOfClass("Humanoid");if not hum then return end
        hum.MaxHealth=math.huge;hum.Health=math.huge
        hum.BreakJointsOnDeath=false
        pcall(function() hum.RequiresNeck=false end)
        local ff=Instance.new("ForceField");ff.Visible=false;ff.Parent=char
        local c1=hum:GetPropertyChangedSignal("Health"):Connect(function()
            if GodMode.active and hum and hum.Parent and hum.Health<math.huge*0.5 then
                hum.Health=math.huge end
        end); table.insert(GodMode.connections,c1)
        local c2=hum:GetPropertyChangedSignal("MaxHealth"):Connect(function()
            if GodMode.active and hum then hum.MaxHealth=math.huge end
        end); table.insert(GodMode.connections,c2)
        local c3=char.ChildRemoved:Connect(function(child)
            if GodMode.active and child:IsA("ForceField") then
                local nff=Instance.new("ForceField");nff.Visible=false;nff.Parent=char end
        end); table.insert(GodMode.connections,c3)
        local c4=hum.Died:Connect(function()
            if GodMode.active then
                task.defer(function()
                    if hum and hum.Parent then hum.Health=math.huge end
                end)
            end
        end); table.insert(GodMode.connections,c4)
        local c5=RS.Heartbeat:Connect(function()
            if not GodMode.active then return end
            local h=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h and h~=hum then task.spawn(apply);return end
            if h and h.Health<1 then h.Health=math.huge end
        end); table.insert(GodMode.connections,c5)
        local root=char:FindFirstChild("HumanoidRootPart")
        if root then
            local c6=root:GetPropertyChangedSignal("Anchored"):Connect(function()
                if GodMode.active and root.Anchored then root.Anchored=false end
            end); table.insert(GodMode.connections,c6)
        end
    end
    apply()
end

local function disableGodMode()
    GodMode.active=false
    for _,c in ipairs(GodMode.connections) do pcall(function() c:Disconnect() end) end
    GodMode.connections={}
    local char=LP.Character
    if char then
        local ff=char:FindFirstChildOfClass("ForceField");if ff then ff:Destroy() end
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum then hum.MaxHealth=100;hum.Health=100 end
    end
end

