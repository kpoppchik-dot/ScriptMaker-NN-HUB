-- FIX #6/#7: Spider — RaycastParams вместо устаревшего Ray.new
local Spider={active=false,connection=nil}
local function enableSpider()
    if Spider.active then return end;Spider.active=true
    local params=RaycastParams.new()
    params.FilterType=Enum.RaycastFilterType.Exclude
    Spider.connection=RS.Heartbeat:Connect(function()
        if not Spider.active then return end
        local char=LP.Character;if not char then return end
        local root=char:FindFirstChild("HumanoidRootPart");if not root then return end
        params.FilterDescendantsInstances={char}
        local result=workspace:Raycast(root.Position,Vector3.new(0,-5,0),params)
        if not result then
            -- FIX #7: AssemblyLinearVelocity вместо .Velocity
            pcall(function()
                root.AssemblyLinearVelocity=root.AssemblyLinearVelocity+Vector3.new(0,50,0)
            end)
        end
    end)
end
local function disableSpider()
    Spider.active=false
    if Spider.connection then Spider.connection:Disconnect();Spider.connection=nil end
end

-- VANISH
local Vanish={active=false}
local function enableVanish()
    Vanish.active=true
    local char=LP.Character;if not char then return end
    for _,v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Accessory") then
            pcall(function() v.Transparency=1 end)
        end
    end
end
local function disableVanish()
    Vanish.active=false
    local char=LP.Character;if not char then return end
    for _,v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Accessory") then
            pcall(function() v.Transparency=0 end)
        end
    end
end

