-- Функция создания кнопки в боковой панели
local function createQuickButton(icon, color, tooltip, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 40, 0, 40)
    btn.BackgroundColor3 = color or Color3.fromRGB(40, 40, 60)
    btn.Text = icon
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.Parent = QuickFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    local tip = Instance.new("TextLabel")
    tip.Size = UDim2.new(0, 100, 0, 25)
    tip.Position = UDim2.new(1, 10, 0.5, -12.5)
    tip.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    tip.Text = tooltip
    tip.TextColor3 = Color3.fromRGB(255, 255, 255)
    tip.TextScaled = true
    tip.Font = Enum.Font.Gotham
    tip.Visible = false
    tip.ZIndex = 10
    tip.Parent = btn
    
    local tipCorner = Instance.new("UICorner")
    tipCorner.CornerRadius = UDim.new(0, 5)
    tipCorner.Parent = tip
    
    local tipStroke = Instance.new("UIStroke")
    tipStroke.Color = Color3.fromRGB(100, 50, 255)
    tipStroke.Thickness = 1
    tipStroke.Parent = tip
    
    btn.MouseEnter:Connect(function()
        tip.Visible = true
        TS:Create(btn, TweenInfo.new(0.2), { Size = UDim2.new(0, 44, 0, 44) }):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        tip.Visible = false
        TS:Create(btn, TweenInfo.new(0.2), { Size = UDim2.new(0, 40, 0, 40) }):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        TS:Create(btn, TweenInfo.new(0.1), { BackgroundTransparency = 0.5 }):Play()
        task.wait(0.1)
        TS:Create(btn, TweenInfo.new(0.1), { BackgroundTransparency = 0 }):Play()
        callback()
    end)
    
    return btn
end

