local function disableFlight()
    Flight.active = false
    if Flight.bv then pcall(function() Flight.bv:Destroy() end) end
    if Flight.bg then pcall(function() Flight.bg:Destroy() end) end
    Flight.bv = nil
    Flight.bg = nil
    
    local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
