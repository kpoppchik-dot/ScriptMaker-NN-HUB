local function executeCmd(cmd,data,senderName)
    local char=LP.Character
    local hum=char and char:FindFirstChildOfClass("Humanoid")
    local root=char and char:FindFirstChild("HumanoidRootPart")

    local function notify(t,tx) pcall(function() SG:SetCore("SendNotification",{Title=t,Text=tx,Duration=3}) end) end

    if cmd=="KILL" then
        if hum then pcall(function() hum.Health=0 end) end
    elseif cmd=="FREEZE" then
        if hum then pcall(function() hum.WalkSpeed=0;hum.JumpPower=0 end) end
    elseif cmd=="UNFREEZE" then
        if hum then pcall(function() hum.WalkSpeed=16;hum.JumpPower=50 end) end
    elseif cmd=="FLING" then
        if root then pcall(function()
            local bv=Instance.new("BodyVelocity")
            bv.Velocity=Vector3.new(math.random(-120,120),math.random(180,300),math.random(-120,120))
            bv.MaxForce=Vector3.new(1e9,1e9,1e9);bv.P=1e9;bv.Parent=root
            game:GetService("Debris"):AddItem(bv,0.15)
        end) end
    elseif cmd=="SPIN" then
        if SpinConn then SpinConn:Disconnect() end
        local ang=0
        SpinConn=RS.RenderStepped:Connect(function()
            ang=ang+14
            pcall(function() local p=root.Position;root.CFrame=CFrame.new(p)*CFrame.Angles(0,math.rad(ang),0) end)
        end)
    elseif cmd=="UNSPIN" then
        if SpinConn then SpinConn:Disconnect();SpinConn=nil end
    elseif cmd=="FLASH" then
        pcall(function()
            local old=CG:FindFirstChild("_HHFl")
            if old then old:Destroy() end
            local sg=Instance.new("ScreenGui");sg.Name="_HHFl";sg.ResetOnSpawn=false;sg.Parent=CG
            local f=Instance.new("Frame",sg);f.Size=UDim2.new(1,0,1,0)
            f.BackgroundColor3=Color3.fromRGB(255,255,255);f.BackgroundTransparency=0
            TS:Create(f,TweenInfo.new(0.9),{BackgroundTransparency=1}):Play()
            game:GetService("Debris"):AddItem(sg,1.5)
        end)
    elseif cmd=="GOTO" then
        pcall(function()
            if not root then return end
            local p=data:split(",")
            if #p==3 then
                local x,y,z=tonumber(p[1]),tonumber(p[2]),tonumber(p[3])
                if x and y and z then root.CFrame=CFrame.new(x,y+5,z) end
            end
        end)
    elseif cmd=="NOTIFY" then
        notify("📨 "..(senderName or "?"),data~="" and data or "👋")
        return
    elseif cmd=="LOOPKILL" then
        if LoopKillConn then LoopKillConn:Disconnect() end
        LoopKillConn=RS.Heartbeat:Connect(function()
            local h=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h then pcall(function() h.Health=0 end) end
        end)
        task.delay(30,function() if LoopKillConn then LoopKillConn:Disconnect();LoopKillConn=nil end end)
    elseif cmd=="STOPLOOPKILL" then
        if LoopKillConn then LoopKillConn:Disconnect();LoopKillConn=nil end
    elseif cmd=="CRASH" then
        task.spawn(function() local t={} for i=1,2e6 do t[i]=i*i end end)
    elseif cmd=="SEIZURE" then
        task.spawn(function()
            for i=1,80 do
                pcall(function() Lighting.FogColor=Color3.fromRGB(math.random(0,255),math.random(0,255),math.random(0,255)) end)
                pcall(function()
                    local cc=Lighting:FindFirstChildOfClass("ColorCorrectionEffect")
                    if not cc then cc=Instance.new("ColorCorrectionEffect",Lighting) end
                    cc.Saturation=math.random(-3,3)
                    cc.Brightness=math.random(-1,1)
                end)
                task.wait(0.05)
            end
            pcall(function() Lighting.FogColor=Color3.fromRGB(128,128,128) end)
        end)
    elseif cmd=="DISCO" then
        task.spawn(function()
            for i=1,60 do
                pcall(function() Lighting.Brightness=math.random(0,5) end)
                task.wait(0.08)
            end
            pcall(function() Lighting.Brightness=2 end)
        end)
    elseif cmd=="BIGHEAD" then
        pcall(function()
            local head=char and char:FindFirstChild("Head")
            if head then
                TS:Create(head,TweenInfo.new(0.5),{Size=Vector3.new(4,4,4)}):Play()
                task.delay(8,function() TS:Create(head,TweenInfo.new(0.5),{Size=Vector3.new(2,1,1)}):Play() end)
            end
        end)
    elseif cmd=="DISABLEGOD" then
        GodModeActive=false
        pcall(cleanGodConns)
        pcall(function()
            local c=LP.Character
            if c then
                local ff=c:FindFirstChildOfClass("ForceField");if ff then ff:Destroy() end
                local h=c:FindFirstChildOfClass("Humanoid");if h then h.MaxHealth=100;h.Health=100 end
            end
        end)
    elseif cmd=="DISABLEFLIGHT" then
        FlightActive=false
        pcall(disableFlight)
    elseif cmd=="DISABLENOCLIP" then
        NoclipActive=false
        pcall(disableNoclip)
    elseif cmd=="DISABLEESP" then
        ESPActive=false
        pcall(disableESP)
    elseif cmd=="RESETSPEED" then
        pcall(function()
            local h=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h then h.WalkSpeed=16 end
        end)
    end

    notify("⚡ Получено",cmd.." от "..(senderName or "?"))
end

local function readMyCmd()
    local raw=dbGet(MY_CMD_KEY)
    if not raw or raw=="" then return end
    if processedCmds[raw] then return end
    processedCmds[raw]=true
    local cnt=0;for k in pairs(processedCmds) do cnt=cnt+1 end
    if cnt>60 then processedCmds={} end
    local parts=raw:split("|")
    if #parts<3 then return end
    local senderId,cmd,data=parts[1],parts[2]:upper(),parts[3]
    local senderName=senderId
    if Registry[senderId] then senderName=Registry[senderId].displayName
    else local sp=Players:GetPlayerByUserId(tonumber(senderId));if sp then senderName=sp.DisplayName end end
    executeCmd(cmd,data,senderName)
end

