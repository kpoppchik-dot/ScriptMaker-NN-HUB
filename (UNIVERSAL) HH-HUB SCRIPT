enableESP = function()
    disableESP()
    ESPActive=true
    local function addESP(plr)
        if plr==LP then return end
        local function update()
            if not ESPActive then return end
            local char=plr.Character
            if not char then
                if ESP_Highlights[plr] then
                    pcall(function() ESP_Highlights[plr]:Destroy() end)
                    ESP_Highlights[plr]=nil
                end
                return
            end
            if not ESP_Highlights[plr] or not ESP_Highlights[plr].Parent then
                local hl=Instance.new("Highlight")
                hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                hl.FillColor=Color3.fromRGB(255,50,50)
                hl.OutlineColor=Color3.fromRGB(255,255,255)
                hl.FillTransparency=0.5
                hl.OutlineTransparency=0
                hl.Parent=char
                ESP_Highlights[plr]=hl
            end
        end
        plr.CharacterAdded:Connect(function() task.wait(0.5);update() end)
        update()
    end
    for _,plr in ipairs(Players:GetPlayers()) do addESP(plr) end
    Players.PlayerAdded:Connect(addESP)
    Players.PlayerRemoving:Connect(function(plr)
        if ESP_Highlights[plr] then
            pcall(function() ESP_Highlights[plr]:Destroy() end)
            ESP_Highlights[plr]=nil
        end
    end)
end

