local function enableGodMode()
    if GodMode.active then return end
    GodMode.active = true
    
    local char = LP.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    hum.MaxHealth = 9e9
    hum.Health = 9e9
    hum.BreakJointsOnDeath = false
    
    local ff = Instance.new("ForceField")
    ff.Visible = false
    ff.Parent = char
    
    table.insert(GodMode.connections, hum:GetPropertyChangedSignal("Health"):Connect(function()
        if GodMode.active and hum and hum.Parent and hum.Health < 9e9 then
            hum.Health = 9e9
        end
    end))
    
    table.insert(GodMode.connections, hum:GetPropertyChangedSignal("MaxHealth"):Connect(function()
        if GodMode.active and hum then
            hum.MaxHealth = 9e9
        end
    end))
    
    table.insert(GodMode.connections, char.ChildRemoved:Connect(function(child)
        if GodMode.active and child:IsA("ForceField") then
            local newFF = Instance.new("ForceField")
            newFF.Visible = false
            newFF.Parent = char
        end
    end))
    
    table.insert(GodMode.connections, RS.Heartbeat:Connect(function()
        if GodMode.active then
            local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h and h.Health < 9e9 then
