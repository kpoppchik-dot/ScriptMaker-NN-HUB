        end
        local players=jsonblobGet(PRESENCE_BLOB_ID)
        if type(players)~="table" then return end
        local searchText=searchBox.Text:lower()
        local total,same,bd=0,0,0
        for uid,info in pairs(players) do
            if type(info)~="table" then continue end
            total=total+1
            if info.same then same=same+1 end
            if info.hasBackdoor then bd=bd+1 end
            if searchText=="" or (info.name and info.name:lower():find(searchText,1,true)) then
                addPlayerCard(uid,info)
            end
        end
        totalLbl.Text="Всего: "..total
        sameLbl.Text="В сервере: "..same
        bdLbl.Text="Бекдор: "..bd
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function() pcall(refreshList) end)
    refreshBtn.MouseButton1Click:Connect(function() pcall(refreshList) end)
    pcall(refreshList)

    task.spawn(function()
        while alive do
            task.wait(8)
            if alive then pcall(refreshList) end
        end
    end)
