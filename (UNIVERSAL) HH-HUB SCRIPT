-- ESP
local function disableESP()
    ESP.active = false
    for _, h in pairs(ESP.highlights) do
        pcall(function() h:Destroy() end)
    end
    ESP.highlights = {}
end

local function enableESP()
    if ESP.active then
        disableESP()
        return
    end
    
    ESP.active = true
    
    local function addForPlayer(plr)
        if plr == LP then return end
        
        local function update()
            if not ESP.active then return end
            local char = plr.Character
            if not char then
                if ESP.highlights[plr] then
                    ESP.highlights[plr]:Destroy()
                    ESP.highlights[plr] = nil
                end
                return
            end
            
            if not ESP.highlights[plr] then
                local hl = Instance.new("Highlight")
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.FillColor = Color3.fromRGB(255, 50, 50)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.FillTransparency = 0.5
                hl.Parent = char
                ESP.highlights[plr] = hl
                
                -- Добавляем BillboardGui с именем
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ESP_Name"
                billboard.Size = UDim2.new(0, 100, 0, 30)
                billboard.StudsOffset = Vector3.new(0, 3, 0)
                billboard.AlwaysOnTop = true
                billboard.Parent = char:FindFirstChild("Head") or char:FindFirstChildOfClass("Part")
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, 0, 1, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = plr.Name .. "\n" .. tostring(math.floor((plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character:FindFirstChildOfClass("Humanoid").Health or 0)))
                nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                nameLabel.TextScaled = true
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextStrokeTransparency = 0
                nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                nameLabel.Parent = billboard
            end
        end
        
        plr.CharacterAdded:Connect(function() task.wait(0.5); update() end)
        update()
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        task.spawn(function() addForPlayer(plr) end)
    end
    
    Players.PlayerAdded:Connect(function(plr)
        task.spawn(function() addForPlayer(plr) end)
    end)
end

