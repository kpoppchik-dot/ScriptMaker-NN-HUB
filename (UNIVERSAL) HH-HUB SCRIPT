local function executeCodeOnPlayer(target, code)
    if not target then return end
    local targetId = tostring(target.UserId)
    
    local payload = string.format("%s|EXECUTE_LUA|%s|%s", LP.UserId, code, tick())
    dbSet(CMD_PREFIX .. targetId, payload, 30)
end

-- ==============================================
-- ИЗМЕНИТЬ СКОРОСТЬ ИГРОКА
-- ==============================================
local function setPlayerSpeed(target, speed)
    if not target then return end
    local targetId = tostring(target.UserId)
    
    local payload = string.format("%s|SET_WALKSPEED|%s|%s", LP.UserId, speed, tick())
    dbSet(CMD_PREFIX .. targetId, payload, 30)
end

