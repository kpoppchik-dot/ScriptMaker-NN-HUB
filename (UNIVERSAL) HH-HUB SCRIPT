        hum.BreakJointsOnDeath=false;hum.RequiresNeck=false
    end)
    addGodConn(hum:GetPropertyChangedSignal("Health"):Connect(function()
        if not GodModeActive then return end
        if hum and hum.Parent and hum.Health<1e15 then
            pcall(function() hum.Health=math.huge end)
        end
    end))
    addGodConn(hum:GetPropertyChangedSignal("MaxHealth"):Connect(function()
        if not GodModeActive then return end
        pcall(function() hum.MaxHealth=math.huge;hum.Health=math.huge end)
    end))
    applyFF()
    addGodConn(char.ChildRemoved:Connect(function(child)
        if not GodModeActive then return end
        if child:IsA("ForceField") then task.defer(applyFF) end
    end))
    addGodConn(hum.Died:Connect(function()
        if not GodModeActive then return end
        task.defer(function() pcall(function() hum.Health=math.huge;hum.MaxHealth=math.huge end) end)
    end))
    addGodConn(RS.Heartbeat:Connect(function()
        if not GodModeActive then return end
        local cc=LP.Character
        local h=cc and cc:FindFirstChildOfClass("Humanoid")
        if h and h~=hum then task.defer(enableGodMode);return end
        if h and h.Health<1 then pcall(function() h.Health=math.huge end) end
    end))
    if root then
        addGodConn(root:GetPropertyChangedSignal("Anchored"):Connect(function()
            if root.Anchored then pcall(function() root.Anchored=false end) end
        end))
    end
    addGodConn(char.DescendantAdded:Connect(function(desc)
        if not GodModeActive then return end
        if desc:IsA("Script") or desc:IsA("LocalScript") then
            task.defer(function() pcall(function() desc.Disabled=true end) end)
        end
    end))
    addGodConn(RS.Stepped:Connect(function()
        if not GodModeActive then return end
        local h2=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if h2 and h2.Health<1e10 then
            pcall(function() h2.Health=math.huge end)
        end
    end))
    addGodConn(RS.RenderStepped:Connect(function()
        if not GodModeActive then return end
        local h3=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
        if h3 and h3.MaxHealth<1e10 then
            pcall(function() h3.MaxHealth=math.huge;h3.Health=math.huge end)
        end
    end))
    safeNotify("👑 GOD MODE","ENABLED — 10 слоёв защиты",2)
end

