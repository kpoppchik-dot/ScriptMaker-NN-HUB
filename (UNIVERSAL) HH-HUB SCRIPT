-- HTTP функции
local function dbSet(key, value, ttl)
    pcall(function()
        HS:RequestAsync({
            Url = DB_BASE .. key,
            Method = "POST",
            Headers = { ["Content-Type"] = "text/plain", ["X-Expire"] = tostring(ttl or DB_TTL) },
            Body = tostring(value)
        })
    end)
end

local function dbGet(key)
    local ok, res = pcall(function() return HS:GetAsync(DB_BASE .. key, true) end)
    return ok and res or nil
end

-- Логирование
local function logToDB(message)
    local logEntry = string.format("[%s] %s: %s", os.date("%Y-%m-%d %H:%M:%S"), LP.Name, message)
    local existing = dbGet(MY_LOG_KEY) or ""
    dbSet(MY_LOG_KEY, existing .. "\n" .. logEntry, DB_TTL)
end

