-- ==============================================
-- HTTP ФУНКЦИИ
-- ==============================================
local function sendToBot(endpoint, data)
    local success = pcall(function()
        HS:RequestAsync({
            Url = BOT_URL .. endpoint,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HS:JSONEncode(data)
        })
    end)
    return success
end

local function getFromBot(endpoint)
    local success, result = pcall(function()
        return HS:GetAsync(BOT_URL .. endpoint, true)
    end)
    if success and result then
        local ok, decoded = pcall(function() return HS:JSONDecode(result) end)
        if ok then return decoded end
    end
    return nil
end

