                        local current = 1
                        for i, opt in ipairs(options) do
                            if opt == dropdown.Text then
                                current = i
                                break
                            end
                        end
                        current = current % #options + 1
                        dropdown.Text = options[current]
                        cb(options[current])
                    end)
                end
                
                return section
            end
            
            return tab
        end
        
