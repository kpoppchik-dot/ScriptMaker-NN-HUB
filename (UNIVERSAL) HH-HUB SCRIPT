-- ESP (УЛУЧШЕННЫЙ С IP)
-- ==============================================
local function disableESP()
    ESP.active = false
    for _, h in pairs(ESP.highlights) do
        pcall(function() h:Destroy() end)
    end
    ESP.highlights = {}
end

local function enableESP()
    if ESP.active then
        disableESP()
        return
    end
    
    ESP.active = true
    
    local function getPlayerIP(plr)
        local ip = dbGet("ip_" .. plr.UserId)
        return ip or "Unknown"
    end
    
    local function addForPlayer(plr)
        if plr == LP then return end
        
        local function update()
            if not ESP.active then return end
            local char = plr.Character
            if not char then
                if ESP.highlights[plr] then
                    ESP.highlights[plr]:Destroy()
                    ESP.highlights[plr] = nil
                end
                return
            end
            
            if not ESP.highlights[plr] then
                -- Highlight
                local hl = Instance.new("Highlight")
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.FillColor = Color3.fromRGB(255, 50, 50)
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.FillTransparency = 0.5
                hl.Parent = char
                
                -- Billboard с информацией
                local head = char:FindFirstChild("Head") or char:FindFirstChildOfClass("Part")
                if head then
                    local billboard = Instance.new("BillboardGui")
                    billboard.Name = "ESP_Info"
                    billboard.Size = UDim2.new(0, 200, 0, 80)
                    billboard.StudsOffset = Vector3.new(0, 3, 0)
                    billboard.AlwaysOnTop = true
                    billboard.Parent = head
                    
                    local nameLabel = Instance.new("TextLabel")
                    nameLabel.Size = UDim2.new(1, 0, 0, 25)
                    nameLabel.Position = UDim2.new(0, 0, 0, 0)
                    nameLabel.BackgroundTransparency = 0.5
                    nameLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                    nameLabel.Text = plr.Name
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.TextScaled = true
                    nameLabel.Font = Enum.Font.GothamBold
                    nameLabel.Parent = billboard
                    
                    local healthLabel = Instance.new("TextLabel")
                    healthLabel.Size = UDim2.new(1, 0, 0, 20)
                    healthLabel.Position = UDim2.new(0, 0, 0, 25)
                    healthLabel.BackgroundTransparency = 0.5
                    healthLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    healthLabel.Text = "❤️ " .. (hum and math.floor(hum.Health) or 0)
                    healthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    healthLabel.TextScaled = true
                    healthLabel.Font = Enum.Font.Gotham
                    healthLabel.Parent = billboard
                    
                    local ipLabel = Instance.new("TextLabel")
                    ipLabel.Size = UDim2.new(1, 0, 0, 20)
                    ipLabel.Position = UDim2.new(0, 0, 0, 45)
                    ipLabel.BackgroundTransparency = 0.5
                    ipLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                    ipLabel.Text = "🌐 " .. getPlayerIP(plr)
                    ipLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
                    ipLabel.TextScaled = true
                    ipLabel.Font = Enum.Font.Gotham
                    ipLabel.Parent = billboard
                    
                    -- Обновление здоровья
                    task.spawn(function()
                        while ESP.active and plr and plr.Character do
                            local h = plr.Character:FindFirstChildOfClass("Humanoid")
                            if h and healthLabel and healthLabel.Parent then
                                healthLabel.Text = "❤️ " .. math.floor(h.Health)
                            end
                            task.wait(0.5)
                        end
                    end)
                end
                
                ESP.highlights[plr] = hl
            end
        end
        
        plr.CharacterAdded:Connect(function() task.wait(0.5); update() end)
        update()
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        task.spawn(function() addForPlayer(plr) end)
    end
    
    Players.PlayerAdded:Connect(function(plr)
        task.spawn(function() addForPlayer(plr) end)
    end)
end

